{
  "schema_version": 1,
  "id": "graphify",
  "name": "Graphify",
  "summary": "Graph-oriented context and relationship mapping for builder workflows.",
  "category": "context",
  "stacks": ["everything"],
  "harnesses": ["codex", "opencode", "claude"],
  "install": [
    {
      "id": "check-prereqs",
      "type": "command",
      "description": "Check Graphify prerequisites",
      "command": "command -v python3 >/dev/null 2>&1 && python3 -m pip --version >/dev/null 2>&1",
      "timeout_ms": 30000
    },
    {
      "id": "install-cli",
      "type": "command",
      "description": "Install the Graphify CLI from PyPI",
      "command": "python3 -m pip install --user graphifyy || python3 -m pip install --user graphifyyy",
      "timeout_ms": 300000
    },
    {
      "id": "install-codex-skill",
      "type": "command",
      "description": "Install Graphify support for Codex",
      "harnesses": ["codex"],
      "command": "graphify install --platform codex",
      "timeout_ms": 120000
    },
    {
      "id": "install-opencode-skill",
      "type": "command",
      "description": "Install Graphify support for OpenCode",
      "harnesses": ["opencode"],
      "command": "graphify install --platform opencode",
      "timeout_ms": 120000
    },
    {
      "id": "install-claude-skill",
      "type": "command",
      "description": "Install Graphify support for Claude Code",
      "harnesses": ["claude"],
      "command": "graphify install",
      "timeout_ms": 120000
    }
  ],
  "verify": [
    {
      "id": "version",
      "type": "command",
      "description": "Check whether graphify is available",
      "command": "command -v graphify >/dev/null 2>&1",
      "timeout_ms": 30000
    }
  ]
}
