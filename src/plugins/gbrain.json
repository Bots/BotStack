{
  "schema_version": 1,
  "id": "gbrain",
  "name": "GBrain",
  "summary": "Persistent memory and search for coding agents.",
  "category": "memory",
  "stacks": ["base", "everything"],
  "harnesses": ["codex", "opencode", "claude", "aider", "continue"],
  "install": [
    {
      "id": "cache-dir",
      "type": "mkdir",
      "description": "Create Botstack cache for the GBrain installer helper",
      "target": "${cacheDir}/gbrain"
    },
    {
      "id": "check-prereqs",
      "type": "command",
      "description": "Check GBrain prerequisites",
      "command": "command -v curl >/dev/null 2>&1 && command -v git >/dev/null 2>&1 && command -v bun >/dev/null 2>&1 && command -v jq >/dev/null 2>&1",
      "timeout_ms": 30000
    },
    {
      "id": "install-cli",
      "type": "command",
      "description": "Install the GBrain CLI with GStack's pinned installer",
      "command": "curl -fsSL https://raw.githubusercontent.com/garrytan/gstack/main/bin/gstack-gbrain-install -o \"${cacheDir}/gbrain/gstack-gbrain-install\" && bash \"${cacheDir}/gbrain/gstack-gbrain-install\" --install-dir \"${gbrainInstallDir}\"",
      "timeout_ms": 300000
    },
    {
      "id": "codex-config",
      "type": "toml.merge",
      "description": "Register GBrain notes for Codex users",
      "harnesses": ["codex"],
      "target": "${home}/.codex/config.toml",
      "value": {
        "botstack_gbrain_enabled": true
      }
    },
    {
      "id": "opencode-config",
      "type": "json.merge",
      "description": "Register GBrain notes for OpenCode users",
      "harnesses": ["opencode"],
      "target": "${home}/.config/opencode/opencode.json",
      "value": {
        "botstack": {
          "gbrain": true
        }
      }
    },
    {
      "id": "claude-config",
      "type": "json.merge",
      "description": "Register GBrain notes for Claude Code users",
      "harnesses": ["claude"],
      "target": "${home}/.claude.json",
      "value": {
        "botstack": {
          "gbrain": true
        }
      }
    },
    {
      "id": "continue-config",
      "type": "json.merge",
      "description": "Register GBrain notes for Continue users",
      "harnesses": ["continue"],
      "target": "${home}/.continue/config.json",
      "value": {
        "botstack": {
          "gbrain": true
        }
      }
    }
  ],
  "verify": [
    {
      "id": "version",
      "type": "command",
      "description": "Check whether gbrain is available",
      "command": "command -v gbrain >/dev/null 2>&1",
      "timeout_ms": 30000
    }
  ]
}
