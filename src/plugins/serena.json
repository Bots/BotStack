{
  "schema_version": 1,
  "id": "serena",
  "name": "Serena MCP",
  "summary": "Semantic code intelligence MCP server for agent harnesses.",
  "category": "mcp",
  "stacks": ["base", "everything"],
  "harnesses": ["codex", "opencode", "claude"],
  "install": [
    {
      "id": "tool-dir",
      "type": "mkdir",
      "description": "Create the Serena tool directory",
      "target": "${toolsDir}/serena"
    },
    {
      "id": "check-prereqs",
      "type": "command",
      "description": "Check Serena prerequisites",
      "command": "command -v uv >/dev/null 2>&1",
      "timeout_ms": 30000
    },
    {
      "id": "install-cli",
      "type": "command",
      "description": "Install the Serena CLI with uv",
      "command": "uv tool install --from git+https://github.com/oraios/serena serena",
      "timeout_ms": 300000
    },
    {
      "id": "codex-mcp-note",
      "type": "toml.merge",
      "description": "Record Serena MCP enablement for Codex users",
      "harnesses": ["codex"],
      "target": "${home}/.codex/config.toml",
      "value": {
        "botstack_serena_enabled": true
      }
    },
    {
      "id": "opencode-mcp-note",
      "type": "json.merge",
      "description": "Record Serena MCP enablement for OpenCode users",
      "harnesses": ["opencode"],
      "target": "${home}/.config/opencode/opencode.json",
      "value": {
        "botstack": {
          "serena": true
        }
      }
    },
    {
      "id": "claude-mcp-note",
      "type": "json.merge",
      "description": "Record Serena MCP enablement for Claude Code users",
      "harnesses": ["claude"],
      "target": "${home}/.claude.json",
      "value": {
        "botstack": {
          "serena": true
        }
      }
    }
  ],
  "verify": [
    {
      "id": "version",
      "type": "command",
      "description": "Check whether serena is available",
      "command": "command -v serena >/dev/null 2>&1",
      "timeout_ms": 30000
    }
  ]
}
